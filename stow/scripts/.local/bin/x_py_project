#!/bin/bash

# x_py_project - Scaffold Python project (pyproject.toml, venv, .gitignore)
# Usage: x_py_project [NAME]

usage() {
    cat <<'EOF'
Usage: x_py_project [NAME]

  Creates: pyproject.toml, .venv, .gitignore, src/NAME/
  NAME defaults to current directory name.
EOF
    exit 0
}

cmd_create() {
    local name="${1:-$(basename "$PWD")}"
    [[ -z "$name" ]] && name="app"
    name=$(echo "$name" | tr -cd '[:alnum:]_-')

    mkdir -p "src/$name"
    touch "src/${name}/__init__.py"

    cat > pyproject.toml <<TOML
[build-system]
requires = ["setuptools>=61"]
build-backend = "setuptools.build_meta"

[project]
name = "$name"
version = "0.1.0"
requires-python = ">=3.10"

[tool.setuptools.packages.find]
where = ["src"]
TOML

    cat > .gitignore <<'GIT'
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
.eggs/
.env
GIT

    python3 -m venv .venv
    echo "Created: pyproject.toml, src/$name/, .venv, .gitignore"
    echo "Activate: source .venv/bin/activate"
}

case "${1:-}" in
    -h|--help) usage ;;
    *) cmd_create "$1" ;;
esac
