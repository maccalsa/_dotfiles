#!/usr/bin/env bash
set -euo pipefail

# x_guar_ghous - Ultimate disk space nuke (Nix, Docker, caches, apt, etc.)
# Usage: x_guar_ghous   (interactive, confirms each step)

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
BLUE="\033[0;34m"
BOLD="\033[1m"
RESET="\033[0m"

usage() {
    cat <<'EOF'
Usage: x_guar_ghous

  Ultimate disk space cleanup. Confirms each step before running.
  Cleans: Nix, Docker, /tmp, Maven, Gradle, Go, Python, npm, Cargo,
          apt, old kernels, Snap, journalctl, node_modules (interactive).

  Run with no args for interactive cleanup.
EOF
    exit 0
}

case "${1:-}" in
    -h|--help) usage ;;
esac

echo -e "${BLUE}"
cat << "EOF"
  ____ _  _ ____ ____    ____ _  _ ____ _  _ ____
  | __ |  | |__| |__/    | __ |__| |  | |  | [__
  |__] |__| |  | |  \    |__] |  | |__| |__| ___]
     Cleanup Tool - Safe, Professional, Efficient
EOF
echo -e "${RESET}"

echo -e "${YELLOW}${BOLD}This script will clean up your system.${RESET}"
echo -e "${BOLD}Press [Y] to confirm each cleanup task.${RESET}\n"

# Capture disk usage for $HOME partition (1K blocks)
get_disk_stats() {
    df -k "$HOME" 2>/dev/null | tail -1 | awk '{print $3, $4}'
}
humanize_kb() {
    local k=$1
    [[ -z "$k" || "$k" -lt 0 ]] && k=0
    if [[ $k -ge 1048576 ]]; then
        echo "$(( k / 1048576 ))G"
    elif [[ $k -ge 1024 ]]; then
        echo "$(( k / 1024 ))M"
    else
        echo "${k}K"
    fi
}

read -r BEFORE_USED BEFORE_AVAIL <<< "$(get_disk_stats)"
BEFORE_USED=${BEFORE_USED:-0}
BEFORE_AVAIL=${BEFORE_AVAIL:-0}

confirm() {
    while true; do
        read -rp "Do you want to clean up $1? [Y/n]: " yn
        case $yn in
            [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo "Please answer Y or N." ;;
        esac
    done
}

safe_clear() {
    if [[ -t 1 ]] && command -v clear >/dev/null 2>&1; then
        clear || true
    fi
}

log() { echo -e "${GREEN}[✔]${RESET} $1"; }
warn() { echo -e "${YELLOW}[!]${RESET} $1"; }
error() { echo -e "${RED}[✘]${RESET} $1"; }

### Nix
if command -v nix-env &>/dev/null; then
    if confirm "Nix (remove old generations & garbage collect)"; then
        log "Deleting old Nix generations..."
        nix-env --delete-generations old
        log "Running Nix garbage collection..."
        nix-collect-garbage -d
        log "Nix cleanup complete."
    else
        warn "Skipping Nix cleanup."
    fi
fi

### Docker
if command -v docker &>/dev/null; then
    if confirm "Docker (remove stopped containers, dangling images, volumes)"; then
        log "Cleaning up Docker..."
        docker system prune -af
        log "Docker cleanup complete."
    else
        warn "Skipping Docker cleanup."
    fi
fi

### /tmp
if confirm "/tmp (delete all temporary files)"; then
    log "Cleaning /tmp..."
    if sudo rm -rf /tmp/* 2>/dev/null; then
        log "/tmp cleanup complete."
    else
        warn "Some files in /tmp could not be deleted. Check permissions or running processes."
    fi
else
    warn "Skipping /tmp cleanup."
fi

### Maven
if [[ -d "$HOME/.m2/repository" ]]; then
    if confirm "Maven (.m2 cache, artifacts older than 30 days)"; then
        log "Cleaning old Maven artifacts..."
        find "$HOME/.m2/repository" -depth -mindepth 1 -maxdepth 6 -type d -mtime +30 -print0 2>/dev/null | xargs -0 -r rm -rf 2>/dev/null || true
        log "Maven cleanup complete."
    else
        warn "Skipping Maven cleanup."
    fi
fi

### Gradle
if [[ -d "$HOME/.gradle/caches/modules-2" ]]; then
    if confirm "Gradle (module cache)"; then
        log "Cleaning Gradle caches..."
        rm -rf ~/.gradle/caches/modules-2/*
        log "Gradle cleanup complete."
    else
        warn "Skipping Gradle cleanup."
    fi
fi

### Go
if command -v go &>/dev/null; then
    go_mod_path=$(go env GOPATH 2>/dev/null)/pkg/mod
    if confirm "Go (remove module cache from ${go_mod_path:-GOPATH/pkg/mod})"; then
        log "Cleaning Go module cache..."
        go clean -modcache
        log "Go cleanup complete."
    else
        warn "Skipping Go cleanup."
    fi
fi

### Python
if command -v python3 &>/dev/null; then
    if confirm "Python (pip cache purge)"; then
        log "Cleaning Python pip cache..."
        python3 -m pip cache purge 2>/dev/null || pip3 cache purge 2>/dev/null || warn "pip cache purge failed"
        log "Python cleanup complete."
    else
        warn "Skipping Python cleanup."
    fi
fi

### npm / pnpm / yarn cache
if command -v npm &>/dev/null || [[ -d "$HOME/.npm" ]]; then
    if confirm "npm cache"; then
        log "Cleaning npm cache..."
        npm cache clean --force 2>/dev/null || rm -rf "$HOME/.npm/_cacache" 2>/dev/null
        log "npm cleanup complete."
    else
        warn "Skipping npm cleanup."
    fi
fi
if command -v pnpm &>/dev/null; then
    if confirm "pnpm store prune"; then
        log "Pruning pnpm store..."
        pnpm store prune 2>/dev/null
        log "pnpm cleanup complete."
    else
        warn "Skipping pnpm cleanup."
    fi
fi
if command -v yarn &>/dev/null; then
    if confirm "yarn cache clean"; then
        log "Cleaning yarn cache..."
        yarn cache clean 2>/dev/null
        log "yarn cleanup complete."
    else
        warn "Skipping yarn cleanup."
    fi
fi

### Cargo
if command -v cargo &>/dev/null && [[ -d "$HOME/.cargo/registry" ]]; then
    if confirm "Cargo (registry cache)"; then
        log "Cleaning Cargo cache..."
        if command -v cargo-cache &>/dev/null; then
            cargo-cache -a 2>/dev/null || true
        else
            rm -rf "$HOME/.cargo/registry/cache" 2>/dev/null || true
        fi
        log "Cargo cleanup complete."
    else
        warn "Skipping Cargo cleanup."
    fi
fi

### apt (Debian/Ubuntu)
if command -v apt-get &>/dev/null; then
    if confirm "apt (clean, autoclean, autoremove)"; then
        log "Cleaning apt..."
        sudo apt-get clean
        sudo apt-get autoclean
        sudo apt-get autoremove -y
        log "apt cleanup complete."
    else
        warn "Skipping apt cleanup."
    fi

    ### Old kernels (purge leftover configs)
    if confirm "old kernels (purge leftover package configs)"; then
        log "Purging old kernel configs..."
        pkgs=$(dpkg -l 'linux-*' 2>/dev/null | awk '/^rc/{print $2}' | tr '\n' ' ')
        if [[ -n "$pkgs" ]]; then
            sudo apt-get remove --purge $pkgs 2>/dev/null || true
        fi
        log "Old kernels cleanup complete."
    else
        warn "Skipping old kernels cleanup."
    fi
fi

### Snap
if command -v snap &>/dev/null; then
    if confirm "Snap (remove disabled revisions)"; then
        log "Cleaning Snap..."
        sudo snap list --all 2>/dev/null | awk '/disabled/{print $1, $3}' |
            while read -r snapname revision; do
                sudo snap remove "$snapname" --revision="$revision" 2>/dev/null || true
            done
        log "Snap cleanup complete."
    else
        warn "Skipping Snap cleanup."
    fi
fi

### Journalctl (keep 3 days - was 1s which wipes everything)
if command -v journalctl &>/dev/null; then
    if confirm "journalctl (vacuum logs older than 3 days)"; then
        log "Cleaning journalctl..."
        sudo journalctl --vacuum-time=3d
        log "Journalctl cleanup complete."
    else
        warn "Skipping journalctl cleanup."
    fi
fi

### Node modules (interactive)
if confirm "Find node_modules folders for interactive cleanup"; then
    echo -e "${GREEN}[✔]${RESET} Finding node_modules in home..."
    mapfile -t NODE_MODULES < <(find "$HOME" -type d -not -path '*/\.*/*' -name "node_modules" -prune 2>/dev/null || true)
    total_folders=${#NODE_MODULES[@]}

    if [[ $total_folders -eq 0 ]]; then
        warn "No node_modules folders found."
    else
        log "Found $total_folders node_modules folders."
        current=0
        while [[ $current -lt $total_folders ]]; do
            folder="${NODE_MODULES[$current]}"
            echo -e "\n${GREEN}Node Modules Cleanup${RESET}"
            echo -e "${BOLD}Found: $total_folders | Current: $((current + 1))${RESET}\n"
            echo -e "d=delete  s=skip  x=exit"
            echo -e "${BLUE}----------------------------------------${RESET}"
            echo -e "${YELLOW}[$((current + 1))/$total_folders] $folder${RESET}"
            read -n 1 -r -p "Action (d/s/x)? " action
            echo

            case $action in
                d|D)
                    if [[ -d "$folder" ]]; then
                        rm -rf "$folder" 2>/dev/null && { log "Deleted: $folder"; } || error "Failed: $folder"
                    else
                        warn "Folder no longer exists."
                    fi
                    ((current += 1))
                    safe_clear
                    ;;
                s|S)
                    warn "Skipped: $folder"
                    ((current += 1))
                    safe_clear
                    ;;
                x|X)
                    warn "Exiting node_modules cleanup."
                    break
                    ;;
                *)
                    warn "Press d, s, or x"
                    safe_clear
                    ;;
            esac
        done
    fi
    log "Node modules cleanup complete."
else
    warn "Skipping node_modules cleanup."
fi

# Disk space summary
read -r AFTER_USED AFTER_AVAIL <<< "$(get_disk_stats)"
AFTER_USED=${AFTER_USED:-0}
AFTER_AVAIL=${AFTER_AVAIL:-0}
SAVED_KB=$((AFTER_AVAIL - BEFORE_AVAIL))

echo ""
echo -e "${GREEN}${BOLD}Cleanup completed! Your system is now clean and optimized.${RESET}"
echo ""
echo -e "${BOLD}Disk space ($(df -h "$HOME" 2>/dev/null | tail -1 | awk '{print $NF}')):${RESET}"
echo -e "  Before:  Used $(humanize_kb "$BEFORE_USED")  |  Available $(humanize_kb "$BEFORE_AVAIL")"
echo -e "  After:   Used $(humanize_kb "$AFTER_USED")  |  Available $(humanize_kb "$AFTER_AVAIL")"
if [[ $SAVED_KB -gt 0 ]]; then
    echo -e "  ${GREEN}Saved:   $(humanize_kb "$SAVED_KB")${RESET}"
elif [[ $SAVED_KB -lt 0 ]]; then
    echo -e "  ${YELLOW}Note:    $(humanize_kb "${SAVED_KB#-}") less available (other activity)${RESET}"
fi
echo ""
