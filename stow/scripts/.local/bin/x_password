#!/bin/bash

# x_password - Generate random password
# Usage: x_password [LEN] [OPTIONS]

usage() {
    cat <<'EOF'
Usage: x_password [LEN]

  Generates random password. LEN defaults to 24.
  Uses alphanumeric + common symbols. Copies to clipboard if xclip/xsel available.

  Examples:
    x_password
    x_password 32
EOF
    exit 0
}

gen_pass() {
    local len="${1:-24}"
    [[ "$len" =~ ^[0-9]+$ ]] || len=24
    LC_ALL=C tr -dc 'A-Za-z0-9!@#$%^&*()_+-=[]{}|;:,.<>?' < /dev/urandom 2>/dev/null | head -c "$len"
    echo
}

case "${1:-}" in
    -h|--help) usage ;;
esac

pass=$(gen_pass "${1:-24}")
echo "$pass"

if command -v xclip &>/dev/null; then
    echo -n "$pass" | xclip -selection clipboard 2>/dev/null && echo "(copied to clipboard)"
elif command -v xsel &>/dev/null; then
    echo -n "$pass" | xsel --clipboard 2>/dev/null && echo "(copied to clipboard)"
fi
